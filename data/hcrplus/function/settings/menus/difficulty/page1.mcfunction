execute unless score hcrplus_settings hcrplus_difficulty_mode matches 0..3 run scoreboard players set hcrplus_settings hcrplus_difficulty_mode 0

tellraw @s ["\n",{"text":" Hardcore Revive+ ","color":"red"},{"text":"| ","color":"dark_gray"},{"text":"Difficulty","color":"gray"},"\n "]

execute if score hcrplus_settings hcrplus_difficulty_mode matches 0 run tellraw @s [" ",{"color":"gray","hover_event":{"action":"show_text","value":[{"text":"Respect the server/world difficulty. HCRPlus will not change it."}]},"text":"ⓘ"},{"color":"gray","text":" Difficulty Mode: "},{"click_event":{"action":"run_command","command":"/trigger hcrplus_difficulty_easy set 1"},"color":"green","hover_event":{"action":"show_text","value":[{"text":"Click to change this setting"}]},"text":"Respect Server"},{"text":"\n "}]
execute if score hcrplus_settings hcrplus_difficulty_mode matches 1 run tellraw @s [" ",{"color":"gray","hover_event":{"action":"show_text","value":[{"text":"HCRPlus forces the server difficulty to Easy."}]},"text":"ⓘ"},{"color":"gray","text":" Difficulty Mode: "},{"click_event":{"action":"run_command","command":"/trigger hcrplus_difficulty_normal set 1"},"color":"yellow","hover_event":{"action":"show_text","value":[{"text":"Click to change this setting"}]},"text":"Force Easy"},{"text":"\n "}]
execute if score hcrplus_settings hcrplus_difficulty_mode matches 2 run tellraw @s [" ",{"color":"gray","hover_event":{"action":"show_text","value":[{"text":"HCRPlus forces the server difficulty to Normal."}]},"text":"ⓘ"},{"color":"gray","text":" Difficulty Mode: "},{"click_event":{"action":"run_command","command":"/trigger hcrplus_difficulty_hard set 1"},"color":"yellow","hover_event":{"action":"show_text","value":[{"text":"Click to change this setting"}]},"text":"Force Normal"},{"text":"\n "}]
execute if score hcrplus_settings hcrplus_difficulty_mode matches 3 run tellraw @s [" ",{"color":"gray","hover_event":{"action":"show_text","value":[{"text":"HCRPlus forces the server difficulty to Hard."}]},"text":"ⓘ"},{"color":"gray","text":" Difficulty Mode: "},{"click_event":{"action":"run_command","command":"/trigger hcrplus_difficulty_respect set 1"},"color":"red","hover_event":{"action":"show_text","value":[{"text":"Click to change this setting"}]},"text":"Force Hard"},{"text":"\n "}]

tellraw @s [" ",{"click_event":{"action":"run_command","command":"/trigger _hcrplus_settings set 1"},"color":"yellow","hover_event":{"action":"show_text","value":[{"text":"Return"}]},"text":"<-- Return"},{"text":"\n "}]

playsound entity.experience_orb.pickup player @s ~ ~ ~ 0.6 1
